{
  "name": "pdf-sign-extension",
  "displayName": "PDF Sign — Sign & Fill PDFs in Browser",
  "version": "1.1.0",
  "description": "Sign & fill PDFs privately — draw signatures, add text, download instantly. First file free, then subscribe. Google sign-in required",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.39.0",
    "extpay": "^3.1.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "4.10.38",
    "plasmo": "^0.89.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "signature_pad": "^4.1.7"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  },
  "manifest": {
    "permissions": [
      "storage",
      "identity"
    ],
    "oauth2": {
      "client_id": "836027625583-4ai30de2tvaduepb4vgink6jm8nnjosg.apps.googleusercontent.com",
      "scopes": [
        "openid",
        "email",
        "profile"
      ]
    },
    "host_permissions": [
      "https://zeavnlowvyvewvysfxmj.supabase.co/*"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "assets/pdf.worker.min.mjs",
          "assets/fonts/*.ttf"
        ],
        "matches": []
      }
    ]
  }
}
